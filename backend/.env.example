# ============================================================================
# N.I.N.A. AI Cortex - Environment Configuration
# ============================================================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Все переменные помечены как:
#   [REQUIRED] - обязательные для production
#   [OPTIONAL] - опциональные, имеют значения по умолчанию
#   [DEV ONLY] - только для разработки
# ============================================================================

# ============================================================================
# ENVIRONMENT - Режим работы
# ============================================================================
# [OPTIONAL]
# Режим окружения: development, staging, production
# В production режиме:
# - VAULT_MASTER_PASSWORD обязателен (нет fallback на dev-пароль)
# - JWT_SECRET обязателен (нет эфемерного секрета)
# - Дефолтные пароли отключены
# - Все секреты должны быть заданы явно
ENVIRONMENT=development

# ============================================================================
# INFUXDB - Time-series база данных для метрик
# ============================================================================
# [REQUIRED в production]
# Токен аутентификации InfluxDB 2.x
#
# Как получить:
# 1. Откройте InfluxDB UI: http://localhost:8086
# 2. Перейдите в Data > Tokens
# 3. Нажмите "Generate Token" > "All Access Token" (или Read/Write для конкретного bucket)
# 4. Скопируйте сгенерированный токен
#
# Генерация через CLI (если установлен influx):
#   influx auth create --org observatory --all-access --description "Cortex Backend"
#
# Пример значения:
#   UVvJCtl-ihRqop4tsoXMlUcCcPAKnIHfoGzQRcuAp2LXhD_cTJMLN0Iy2l3_4aReWB_kdFEKezLhkv5ioQFu-A==
INFLUXDB_TOKEN=your-influxdb-token-here

# ============================================================================
# HOME ASSISTANT - Интеграция с умным домом
# ============================================================================
# [OPTIONAL]
# Long-Lived Access Token из Home Assistant
#
# Как получить:
# 1. Откройте Home Assistant UI
# 2. Перейдите в Profile (кликните на имя пользователя внизу слева)
# 3. Прокрутите до секции "Security"
# 4. Найдите "Long-Lived Access Tokens"
# 5. Нажмите "Create Token"
# 6. Введите имя (например, "NINA Cortex")
# 7. Скопируйте сгенерированный токен (показывается ОДИН раз!)
#
# Пример значения:
#   eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJkZTgzN2ZjMmQwYjQ0...
HA_TOKEN=

# ============================================================================
# CREDENTIAL VAULT - Безопасное хранение секретов
# ============================================================================
# [REQUIRED в production]
# Мастер-пароль для шифрования Vault (Argon2id + AES-256-GCM)
#
# Требования:
# - Минимум 16 символов (рекомендуется 32+)
# - Используйте случайную строку (не "password123"!)
# - В production НЕЛЬЗЯ использовать dev-пароли
#
# Генерация (Python):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Генерация (PowerShell):
#   -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | ForEach-Object {[char]$_})
#
# Генерация (bash):
#   openssl rand -base64 32
#
# Пример значения:
#   8Kj3mN9pQ2wR5tY7uI0oP4sL6vB1cX8zA3eF5gH7jK9mN2pQ
VAULT_MASTER_PASSWORD=

# ============================================================================
# OLLAMA - Локальный LLM сервер
# ============================================================================
# [OPTIONAL]
# Хост Ollama (по умолчанию localhost:11434)
OLLAMA_HOST=http://localhost:11434

# [OPTIONAL]
# Основная модель LLM (облачная, мощная)
# Используется для: Diagnostician, Strategist, Auditor, Copilot
# Загрузка: ollama pull gemma4:31b-cloud
LLM_PRIMARY_MODEL=gemma4:31b-cloud

# [OPTIONAL]
# Fallback модель LLM (локальная, быстрая)
# Используется при недоступности primary или для простых запросов
# Загрузка: ollama pull gemma4:e4b
LLM_FALLBACK_MODEL=gemma4:e4b

# [OPTIONAL]
# Таймауты LLM (секунды)
LLM_PRIMARY_TIMEOUT=30.0
LLM_FALLBACK_TIMEOUT=15.0

# [OPTIONAL]
# Параметры генерации
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.3

# [OPTIONAL]
# Включить/выключить fallback на локальную модель
LLM_FALLBACK_ENABLED=true

# ============================================================================
# API SECURITY - Аутентификация и авторизация
# ============================================================================
# [REQUIRED в production]
# Секретный ключ для подписи JWT токенов
#
# Требования:
# - Минимум 32 символа (рекомендуется 48+)
# - Используйте криптографически стойкую случайную строку
# - В production НЕЛЬЗЯ использовать короткие или предсказуемые секреты
#
# Генерация (Python):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Генерация (PowerShell):
#   -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 48 | ForEach-Object {[char]$_})
#
# Генерация (bash):
#   openssl rand -base64 48
#
# Пример значения:
#   2Kx9mN4pQ7wR0tY3uI6oP9sL2vB5cX8zA1eF4gH7jK0mN3pQ6rS9tU2vW5xY8zA
JWT_SECRET=

# ============================================================================
# CORS - Cross-Origin Resource Sharing
# ============================================================================
# [OPTIONAL в dev, REQUIRED в production]
# Разрешённые домены фронтенда (через запятую)
#
# Для development:
#   http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
#
# Для production (замените на реальные домены):
#   https://cortex.your-domain.com,https://observatory.local
#
# Пример:
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://cortex.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# LOGGING - Настройки логирования
# ============================================================================
# [OPTIONAL]
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
#
# Рекомендации:
# - development: DEBUG (подробные логи для отладки)
# - staging: INFO (баланс между деталями и шумом)
# - production: WARNING (только важные события)
LOG_LEVEL=INFO

# [OPTIONAL]
# Формат логов: json (для production/ELK) или text (для dev)
#
# Рекомендации:
# - development: text (человеко-читаемый)
# - production: json (для парсинга в ELK/Splunk/Datadog)
LOG_FORMAT=json

# ============================================================================
# RATE LIMITING - Защита от перегрузки
# ============================================================================
# [OPTIONAL]
# Максимум запросов в минуту с одного IP (общий лимит)
# Рекомендуется: 120 для development, 60 для production
RATE_LIMIT_PER_MINUTE=120

# [OPTIONAL]
# Максимум запросов к LLM endpoints в минуту (защита Ollama)
# Рекомендуется: 20 для development, 10 для production
LLM_RATE_LIMIT_PER_MINUTE=20

# [OPTIONAL]
# Максимум запросов к trigger endpoints в минуту (защита оборудования)
# Рекомендуется: 30 для development, 15 для production
TRIGGER_RATE_LIMIT_PER_MINUTE=30

# ============================================================================
# ADVANCED SETTINGS - Продвинутые настройки (опционально)
# ============================================================================
# [OPTIONAL]
# Время жизни JWT access token (минуты). 1440 = 24 часа.
# Для production рекомендуется 60-240 (1-4 часа) с refresh tokens
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# [OPTIONAL]
# Включить детальные метрики Prometheus (может увеличить нагрузку)
# Рекомендуется: true для development, false для production (если не нужен мониторинг)
ENABLE_DETAILED_METRICS=true

# [OPTIONAL]
# Включить Decision Audit Trail (сохранение всех решений AI-агентов)
# Рекомендуется: true для всех сред (важно для отладки и аудита)
ENABLE_DECISION_AUDIT=true

# ============================================================================
# CHECKLIST - Проверка перед запуском
# ============================================================================
# Перед запуском в production убедитесь, что:
#
# [ ] ENVIRONMENT=production
# [ ] INFLUXDB_TOKEN задан (не "your-influxdb-token-here")
# [ ] VAULT_MASTER_PASSWORD задан (минимум 32 символа, случайная строка)
# [ ] JWT_SECRET задан (минимум 48 символов, случайная строка)
# [ ] CORS_ALLOWED_ORIGINS содержит только production домены
# [ ] LOG_LEVEL=WARNING (или INFO для staging)
# [ ] LOG_FORMAT=json
# [ ] RATE_LIMIT_PER_MINUTE снижен до 60-100
# [ ] LLM_RATE_LIMIT_PER_MINUTE снижен до 10-15
# [ ] TRIGGER_RATE_LIMIT_PER_MINUTE снижен до 15-20
# [ ] ACCESS_TOKEN_EXPIRE_MINUTES снижен до 60-240
#
# Генерация всех секретов одной командой:
#   python -c "import secrets; print('VAULT_MASTER_PASSWORD=' + secrets.token_urlsafe(32)); print('JWT_SECRET=' + secrets.token_urlsafe(48))"
#
# ============================================================================